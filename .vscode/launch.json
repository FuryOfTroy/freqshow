    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch CLI",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "main.go",
            "args": [
                "eq",
                "--input-file", "example_short.wav",
                "--output-file", "result.wav",
                "--freq-start", "2000",
                "--freq-end", "20000",
                "--gain", "-30"
            ]
        },
        {
            "name": "Launch GUI",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": ".",
            "args": ["gui"],
            "buildFlags": ["-tags", "gui"]
        }
    ]
}